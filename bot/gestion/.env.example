# ============================================================
# .env.example — Variables de entorno para el módulo Gestión
# Agrega estas variables al .env que ya usa el Hermes
# ============================================================

# ── DeepSeek (probablemente ya lo tienes configurado en Hermes) ─
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Groq Whisper (GRATIS — para transcripción de audios de voz) ─
# Crea cuenta gratuita en: https://console.groq.com/keys
# Plan free: 2000 minutos/día de transcripción — más que suficiente
GROQ_API_KEY=gsk_...

# ── Firebase ────────────────────────────────────────────────────
# Descarga el JSON desde Firebase Console > Configuración > Cuentas de servicio
FIREBASE_CRED_PATH=/ruta/al/firebase-credentials.json
FIREBASE_PROJECT_ID=tu-proyecto-firebase

# ── Admins del bot (IDs de Telegram, separados por coma) ────────
# Estos usuarios pueden aprobar/rechazar sin pasar por la lista bot_users
ADMIN_TELEGRAM_IDS=123456789,987654321
